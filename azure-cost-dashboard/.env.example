# ─── Azure AD / Auth ─────────────────────────────────────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Key Vault (production only) ─────────────────────────────────────────────
AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# ─── Database ─────────────────────────────────────────────────────────────────
DB_SERVER=your-sql-server.database.windows.net
DB_PORT=1433
DB_NAME=CostDashboard
DB_USER=sqladmin
DB_PASSWORD=your-db-password
# Set to true to use Azure AD auth instead of SQL auth in production
DB_USE_AAD_AUTH=false

# ─── Redis Cache ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For Azure Cache for Redis (TLS):
# REDIS_URL=rediss://:your-access-key@your-cache.redis.cache.windows.net:6380

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.azurewebsites.net

# ─── Application Insights (optional, production) ─────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ─── Frontend (Vite env vars — prefix VITE_ required) ────────────────────────
# These go in azure-cost-dashboard/frontend/.env.local
VITE_API_BASE_URL=http://localhost:3001
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
